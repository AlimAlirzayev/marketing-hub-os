{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ramin-os.local/social-studio/google-media-campaign.v1.json",
  "title": "Ramin-OS Google Media Campaign",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "campaign", "objective", "evidence", "creative", "outputs", "governance"],
  "properties": {
    "version": {"const": "1"},
    "campaign": {"type":"object","additionalProperties":false,"required":["slug","name","language","owner"],"properties":{"slug":{"type":"string","pattern":"^[a-z0-9]+(?:-[a-z0-9]+)*$"},"name":{"type":"string","minLength":3},"language":{"type":"string","minLength":2},"owner":{"type":"string","minLength":2}}},
    "objective": {"type":"object","additionalProperties":false,"required":["goal","audience","topic","platforms"],"properties":{"goal":{"type":"string","minLength":3},"audience":{"type":"string","minLength":3},"topic":{"type":"string","minLength":3},"platforms":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","enum":["instagram","facebook","linkedin","youtube","tiktok","generic"]}}}},
    "evidence": {"type":"object","additionalProperties":false,"required":["facts","blocked_claims"],"properties":{"facts":{"type":"array","items":{"type":"object","additionalProperties":false,"required":["claim","source_url","status"],"properties":{"claim":{"type":"string","minLength":3},"source_url":{"type":"string","pattern":"^https://"},"status":{"type":"string","enum":["approved","needs_review"]}}}},"blocked_claims":{"type":"array","items":{"type":"string"}}}},
    "creative": {"type":"object","additionalProperties":false,"required":["style","tone","visual_world","music_mood","voice_delivery","cta"],"properties":{"style":{"type":"string"},"tone":{"type":"array","minItems":1,"items":{"type":"string"}},"visual_world":{"type":"string"},"music_mood":{"type":"string"},"voice_delivery":{"type":"string"},"cta":{"type":"string"}}},
    "outputs": {"type":"object","additionalProperties":false,"required":["copy","image","video","music","voice","audio_overview"],"properties":{"copy":{"type":"boolean"},"image":{"type":"boolean"},"video":{"type":"boolean"},"music":{"type":"boolean"},"voice":{"type":"boolean"},"audio_overview":{"type":"boolean"}}},
    "governance": {"type":"object","additionalProperties":false,"required":["data_classification","publish_mode","human_approval_required"],"properties":{"data_classification":{"type":"string","enum":["public","synthetic","approved_campaign"]},"publish_mode":{"const":"draft_only"},"human_approval_required":{"const":true}}}
  }
}
