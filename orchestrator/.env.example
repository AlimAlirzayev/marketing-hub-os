# ============================================================
# Xalq Insurance Digital OS orchestrator - Python environment
# Copy to ".env" and fill in. Subset of the root .env.example.
# ============================================================

# --- LLM providers ---
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=
GROQ_API_KEY=

# Ollama (local, no key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=gemma3:4b

# --- Infrastructure ---
QDRANT_URL=http://localhost:6333
N8N_WEBHOOK_URL=http://localhost:5678/

# --- Default model IDs per routing tier ---
MODEL_COMPLEX=claude-sonnet-4-6
MODEL_FAST=llama-3.3-70b-versatile
MODEL_FREE_BULK=gemini-2.0-flash
MODEL_PRIVATE=gemma3:4b
