# ============================================================
# Xalq Insurance Digital OS - ENVIRONMENT VARIABLES
# Copy this file to ".env" and fill in your values
# ============================================================

# --- Brand profile (which deployment is this machine?) ---
# Selects the brand identity from brand.py. Keep the SAME code everywhere; only
# this value differs per deployment, so git pull/push never fights over branding.
#   xalq   -> Xalq Sigorta (corporate, default)
#   global -> Marketing Hub (generic personal build)
BRAND=xalq

# --- PostgreSQL ---
POSTGRES_USER=ramin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ramin_os

# --- n8n ---
N8N_HOST=localhost
N8N_USER=admin
N8N_PASSWORD=change_me_n8n_admin
N8N_ENCRYPTION_KEY=generate_32_char_random_string_here
WEBHOOK_URL=http://localhost:5678/

# --- Open WebUI ---
WEBUI_SECRET=generate_random_secret

# ============================================================
# LLM PROVIDERS (4-way hybrid)
# ============================================================

# Claude (you already have this)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini 2.0 Flash (FREE tier - 1500 req/day)
# Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Groq (FREE - Llama 3.3 70B)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Ollama (local, no key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=gemma3:4b

# --- Hybrid router extra providers (llm_router.py / LiteLLM) ---
# Free-first 20/80 routing. Leave any blank — the router skips unconfigured ones.
# OpenRouter: one key → DeepSeek/GLM/Qwen/Llama incl. :free models (200 req/day).
OPENROUTER_API_KEY=
# DeepSeek direct (V4 chat + reasoner), very cheap.
DEEPSEEK_API_KEY=
# Cerebras: free, no card, very fast Llama/Qwen.
CEREBRAS_API_KEY=
# Zhipu / GLM (GLM-4.7-Flash free; GLM-5.2 ≈ Opus at ~1/5 cost).
ZHIPU_API_KEY=
# NVIDIA NIM (free, phone verify): DeepSeek/Qwen hosted.
NVIDIA_NIM_API_KEY=
# Optional model overrides (LiteLLM model ids):
# LLM_CHEAP_MODEL=gemini/gemini-2.5-flash
# LLM_SMART_MODEL=gemini/gemini-2.5-pro

# AI Council for Agent Terminal
AI_COUNCIL_ENABLED=1
AI_COUNCIL_AUTO_EXECUTE=1
AI_COUNCIL_ALLOW_API_FALLBACK=0
AI_COUNCIL_TIMEOUT_SECONDS=60
AI_COUNCIL_GEMINI_TIMEOUT_SECONDS=45
AI_COUNCIL_EXECUTION_TIMEOUT_SECONDS=180
AI_COUNCIL_CODEX_EXECUTION_SANDBOX=workspace-write
CLAUDE_COUNCIL_MODEL=sonnet
GEMINI_COUNCIL_CLI_MODEL=gemini-2.5-flash-lite

# --- Knowledge Core / Brain embeddings ---
# Off by default. Keyword recall works without any provider.
# For private semantic recall, run a local/private TEI or OpenAI-compatible
# embedding endpoint and enable these. External endpoints stay blocked unless
# BRAIN_EMBED_ALLOW_EXTERNAL=1 is explicitly set.
BRAIN_RECALL=1
BRAIN_REFLECT=1
BRAIN_EMBEDDINGS=0
BRAIN_EMBED_PROVIDER=auto
BRAIN_EMBED_ENDPOINT=
BRAIN_EMBED_MODEL=
BRAIN_EMBED_ALLOW_EXTERNAL=0
BRAIN_EMBED_TIMEOUT_SECONDS=8
BRAIN_REFLECT_MODEL=gemini-2.5-flash

# ============================================================
# OPTIONAL INTEGRATIONS
# ============================================================

# Telegram bot (from @BotFather)
TELEGRAM_BOT_TOKEN=
# Your own chat id — locks privileged ops commands (/update engine pull) to you.
# Message the bot /start once and it replies with your chat id; paste it here.
TELEGRAM_OWNER_CHAT_ID=
# Always-on host self-sync: supervisor pulls the engine every N minutes (0 = off).
ENGINE_SYNC_MIN=60

# --- Customer Relations Center (complaint radar + AI triage) ---
CX_DATA_MODE=demo
CX_ACCOUNT_NAME=Xalq Sigorta
CX_APP_NAME=Customer Relations Center
CX_ACCOUNT_TAGLINE=Complaint radar, AI triage, SLA and customer recovery
CX_PUBLIC_BASE_URL=
CX_WEBHOOK_SECRET=
CX_META_VERIFY_TOKEN=
CX_META_APP_SECRET=
CX_ALERT_CHAT_ID=
CX_AI_ENABLED=true
CX_GEMINI_MODEL=gemini-3.5-flash
CX_AI_TIMEOUT_SECONDS=5
CX_SYNC_INTERVAL_SECONDS=0

# Optional private Hugging Face sentiment reinforcement for CX triage.
# Off by default. Use a local/private text-classification endpoint only.
CX_HF_SENTIMENT_ENABLED=0
CX_HF_SENTIMENT_ENDPOINT=
CX_HF_SENTIMENT_MODEL=
CX_HF_SENTIMENT_ALLOW_EXTERNAL=0
CX_HF_SENTIMENT_TIMEOUT_SECONDS=4
CX_HF_SENTIMENT_MIN_CONFIDENCE=0.70
CX_HF_SENTIMENT_MAX_CHARS=1200

# Chatplace can POST to /api/webhooks/chatplace. Optional pull mode accepts
# any Chatplace-compatible JSON feed URL returning items/messages/comments.
CHATPLACE_PULL_URL=
CHATPLACE_API_TOKEN=

# Google Business Profile reviews pull connector
GOOGLE_BUSINESS_PROFILE_ACCESS_TOKEN=
GOOGLE_BUSINESS_PROFILE_ACCOUNT_ID=
GOOGLE_BUSINESS_PROFILE_LOCATION_IDS=
GOOGLE_BUSINESS_PROFILE_REVIEW_PAGE_SIZE=50

# Meta live channels. Webhooks use CX_META_* above. Pull sync uses Graph API
# for owned Facebook Page comments and Instagram Business media comments.
META_GRAPH_API_VERSION=v25.0
META_GRAPH_ACCESS_TOKEN=
META_FACEBOOK_PAGE_IDS=
META_INSTAGRAM_BUSINESS_IDS=
META_SYNC_POST_LIMIT=10
META_SYNC_MEDIA_LIMIT=10
META_SYNC_COMMENT_LIMIT=50

# OpenAI (optional fallback)
OPENAI_API_KEY=

# Hugging Face (you're already authenticated)
HF_TOKEN=

# Context7 docs grounding (optional). Leave blank for the default no-key MCP
# flow. If you use an API key for higher limits, keep it local and never paste
# it into tracked MCP settings.
CONTEXT7_API_KEY=
CONTEXT7_ENABLED=1

# Apify (web scraping)
APIFY_API_TOKEN=

# --- Influencer Hunter (Instagram creator intelligence) ---
IH_GEMINI_MODEL=gemini-2.5-flash
IH_GROQ_MODEL=llama-3.3-70b-versatile
IH_DISABLE_LLM=0
IH_DISABLE_APIFY=0
IH_APIFY_TIMEOUT=180
IH_MAX_DISCOVERY_POSTS=80
IH_MAX_PROFILE_HANDLES=24
IH_MAX_POSTS_PER_HANDLE=12
IH_MAX_COMMENTS_PER_POST=25
IH_DEFAULT_MIN_FOLLOWERS=20000
IH_INSTAGRAM_SCRAPER_ACTOR=apify/instagram-scraper
IH_INSTAGRAM_PROFILE_ACTOR=apify/instagram-profile-scraper
IH_INSTAGRAM_POST_ACTOR=apify/instagram-post-scraper
IH_INSTAGRAM_COMMENT_ACTOR=apify/instagram-comment-scraper
IH_INSTAGRAM_HASHTAG_ACTOR=apify/instagram-hashtag-scraper
IH_TELEGRAM_CHAT_ID=

# SmartLead / Mailchimp
SMARTLEAD_API_KEY=

# --- Google Ads API (campaign creation; see ads-studio/GOOGLE_ADS_SETUP.md) ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=   # manager (MCC) id, digits only, no dashes
GOOGLE_ADS_CUSTOMER_ID=         # Xalq Sigorta account id, digits only

# --- Meta Marketing API (already used by ads-studio dashboard reads) ---
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=             # keep the act_ prefix, e.g. act_1022941045861923

# ============================================================
# AUTO-PUBLISH + CONTENT ENGINES (provider cascade)
# See claude-agents/.claude/capabilities.md for how the agent routes these.
# Free-first: leave the paid ones blank and the cascade still works.
# ============================================================

# --- Postiz (PRIMARY publisher: AGPL-3.0, self-hosted, FREE, MCP + API) ---
# Bring it up:  docker compose up -d postiz   (see docker-compose.yml)
# Then open http://localhost:5000, create an account, connect socials, and make
# an API key under Settings → Public API.  https://github.com/gitroomhq/postiz-app
POSTIZ_API_URL=http://localhost:5000
POSTIZ_API_KEY=
# Required by the container before first boot. Generate a long random string:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
POSTIZ_JWT_SECRET=

# --- Blotato (FALLBACK publisher: paid $29/mo, MCP-ready, no real free tier) ---
# Only used if Postiz is unavailable AND this key is present. Starter caps
# apply (e.g. 3 TikTok accounts / 24h) — the router respects them.
BLOTATO_API_KEY=

# --- Higgsfield (PREMIUM clip/video: free ~150 cr/mo, 720p watermark, MCP burns credits) ---
# MCP already added at user scope (~/.claude.json). Used only when the free
# local/HF clip+video path is insufficient and credits remain.
HIGGSFIELD_API_KEY=

# --- FLORA AI (premium creative canvas: official remote MCP + API) ---
# Interactive MCP uses OAuth on first use and does NOT need an API key here.
# Keep FLORA_API_KEY blank unless a server-side automation has been explicitly
# approved and the key is stored only in local secrets.
FLORA_MCP_URL=https://agents.flora.ai/mcp
FLORA_API_KEY=
FLORA_WORKSPACE_ID=
FLORA_DEFAULT_PROJECT_ID=
FLORA_MAX_BATCH_COST_USD=5

# ============================================================
# AUDIO STUDIO - universal music / sfx / voice generator (the "Suno but universal" engine)
# See audio-studio/README.md and the audio-gen cascade in capabilities.md.
# Free-first: Edge TTS + HF Spaces need nothing here; ElevenLabs is the premium engine.
# ============================================================

# --- ElevenLabs (HEADLINE engine: compose_music + sound_effect + text_to_speech +
#     voice cloning, ONE API, FREE 10k credits/mo, official MCP server) ---
# Free key: https://elevenlabs.io/app/settings/api-keys
# Re-run scripts/setup-mcp.ps1 after setting this so the MCP server picks it up.
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE=21m00Tcm4TlvDq8ikWAM   # "Rachel" stock multilingual voice

# --- Free music/sfx via HuggingFace Spaces (used before spending ElevenLabs credits) ---
# HF_TOKEN above improves ZeroGPU quota. Override the spaces if one goes offline (/scout).
AUDIO_HF_MUSIC_SPACE=stabilityai/stable-audio-3
AUDIO_HF_SFX_SPACE=stabilityai/stable-audio-3

# --- Voice cloning (the natural-Azerbaijani path): clones a real human voice (free HF) ---
# Drop a 20-30s clean human clip in audio-studio/voices/, then: clone --ref <clip>
AUDIO_HF_CLONE_SPACE=k2-fsa/OmniVoice

# --- Gemini native-audio TTS (most natural synthetic AZ; the family from the reel) ---
# Uses GEMINI_API_KEY/GOOGLE_API_KEY. Speaks Azerbaijani; 30+ voices (Kore, Charon, Aoede...).
# WARNING: free-tier audio output is NOT licensed for commercial use -> use paid Cloud
# Billing for production renders. tts --provider gemini --voice <name>
AUDIO_GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
AUDIO_GEMINI_VOICE=Kore

# --- Google Lyria 3 via Gemini API (EXPERIMENTAL, may bill; off by default) ---
# Uses GEMINI_API_KEY/GOOGLE_API_KEY above. Free only to test in AI Studio.
AUDIO_ENABLE_LYRIA=0
AUDIO_LYRIA_MODEL=lyria-3-clip-preview

# ============================================================
# SEO ENGINE (seo/) — audit / research / content. Free-first, zero required keys.
# See seo/README.md. The auditor, crawler and Google-Suggest research all work
# with NO key; only Core Web Vitals needs the one optional key below.
# ============================================================

# --- Core Web Vitals (PageSpeed Insights API) — OPTIONAL, free ---
# Without it the auditor labels Core Web Vitals as ƏLÇATMAZ (never fabricates).
# The AI-Studio Gemini key is NOT scoped for this API. To unlock (free, 25k/day):
#   1) console.cloud.google.com → enable "PageSpeed Insights API"
#   2) create an API key → paste here.
PAGESPEED_API_KEY=

# Crawler identity + limits (safe defaults; override only if a site blocks us).
# SEO_USER_AGENT=Mozilla/5.0 (compatible; RaminSEO/0.1; +https://ramin-os.local/seo)
# SEO_FETCH_TIMEOUT=20
# SEO_MAX_HTML_BYTES=3000000
