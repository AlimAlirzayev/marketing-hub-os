# Secrets
.env
.env.*
!.env.example
orchestrator/.env
jarvis/config.yaml

# Runtime state
data/vector_db/*
data/memory/*
data/logs/*
data/agent_radar/*
data/signal_radar/
data/radar/
data/certification_coach/
output/agent-radar/*
output/signal-radar/
output/canvas-lab/
output/*.log
output/*.err.log
tmp/
!data/**/.gitkeep
*.db
*.sqlite
atelier/data/uploads/
atelier/data/browser_profiles/

# Cloned sources / temp
.tmp/
.tools/

# Audio Studio - generated output + private reference voices (keep only READMEs)
audio-studio/output/
audio-studio/voices/*
!audio-studio/voices/README.md
!audio-studio/voices/RECORDING_GUIDE.md

# Video Studio - heavy generated media + portable binaries (token-hygiene: the
# agent should never scan these; they also must never be committed)
video-studio/output/
video-studio/input/*
!video-studio/input/.gitkeep
video-studio/jobs/*
!video-studio/jobs/.gitkeep
video-studio/tools/
video-studio/remotion/node_modules/

# Publisher - generated publish packages
output/publish/

# Media Studio - generated promo packages (brief/prompt/board are regenerable via
# `python -m media_studio "<sentence>"`; keep the tracked kasko reference campaign)
output/media_studio/

# Generated heavy media anywhere under output/ (regenerable renders; ~12MB each).
# Keep text deliverables (.md/.json/.html) and lighter images tracked.
output/**/*.mp4
output/**/*.mov
output/**/*.webm
output/**/*.wav
output/**/*.mp3
output/**/*.m4a

# Research digests (regenerated by scripts/yt_digest.py on demand)
scripts/_digests/

# idea-studio: reference videos are heavy & re-fetchable via yt-dlp (frames +
# analysis.md stay tracked — they are the grounded evidence)
idea-studio/output/**/*.mp4

# Claude Code local permission settings — machine-local, never travels
.claude/settings.local.json

# Autonomous graph runtime state (orchestrator/graph.py) — run log + checkpoints
data/graph_runs.jsonl
data/graph_checkpoints.sqlite*

# Job queue runtime DB (gateway/queue.py) incl. SQLite WAL/SHM siblings
data/jobs.sqlite*

# Headless Claude Code bridge session map (gateway/claude_bridge.py) — local only
data/claude_session.json

# PRIVATE context (business/customer/brand/strategy/conversation) — NEVER travels.
# Only the shared engine (memory/ + code) crosses between systems via git.
data/private_context/

# Python
venv/
.venv/
__pycache__/
*.pyc

# Audit tooling - bundled portable virtualenv (thousands of vendored files)
.audit-tools/

# Node
node_modules/
notion-workers/**/dist/
notion-workers/**/workers.json

# OpenCode local session/cache data (keep opencode.json, ignore runtime state)
.opencode/

# Service runtime logs (stdout/stderr from launched services)
logs/

# Editor / OS
.DS_Store
Thumbs.db

# lab: kod səyahət edir, data yerdə qalır (əkiz qaydası)
lab/knowledge/
lab/logs/
lab/state.json
lab/ledger.json
lab/config.json
lab/KILL
lab/.env

# workspace: agent build sandbox — deliverables are local, not engine code
workspace/

# published: agent-deployed static sites (data, served by caddy)
published/

# --- keep the tree clean so ff-pull never jams (root cause of the 2026-07-08 mailbox jam) ---
# Per-job generated artifacts are DATA (private), not engine — never track them.
output/jobs/
output/media/
output/social/
# Editor/rollback backups clutter `git status` and mask real dirtiness.
*.bak
*.bak.*
*.bak2.*
*.bak3.*
data/postpull_state.json
data/last_sync.json
data/skills/
data/watchdog_state.json
data/logs/watchdog-*.log

# Browser profiles used by lab/QA automation - contain cookies and sessions, never track
data/canvas-lab-profile/

# Ads plan queue - private ops data (intent already stated in gateway/ads_agent.py)
data/ads_plans/
# Chat replies are conversations, not deliverables (see tests/test_deliverables_are_work.py)
output/replies/

# CrewAI orchestration venv (per-machine, ~900MB, never committed)
.venv-crew/
